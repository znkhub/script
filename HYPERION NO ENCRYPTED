            for i = 1, 4 do s = s..c:sub(math.random(1,#c), math.random(1,#c)) end
            return s
        end
        return prefix.."-"..r4().."-"..r4().."-"..r4()
    end

    local function refreshKeyList()
        for _, ch in ipairs(KeyScroll:GetChildren()) do
            if ch:IsA("Frame") then ch:Destroy() end
        end
        local allKeys = {}
        for _, k in pairs(VALID_KEYS) do
            table.insert(allKeys, { key = k, isCustom = false, status = "Permanent (statique)" })
        end
        for _, entry in pairs(loadCustomKeys()) do
            if type(entry) == "table" then
                local rem = ""
                if entry.duration and entry.duration < 999999999 then
                    local elapsed = getCurrentTime() - (entry.createdAt or 0)
                    rem = formatTime(math.max(entry.duration - elapsed, 0))
                else rem = "Permanent" end
                table.insert(allKeys, { key = entry.key, isCustom = true, status = rem })
            elseif type(entry) == "string" then
                table.insert(allKeys, { key = entry, isCustom = true, status = "Permanent" })
            end
        end
        if #allKeys == 0 then
            local emp = Instance.new("TextLabel", KeyScroll)
            emp.Size = UDim2.new(1, 0, 0, 30); emp.BackgroundTransparency = 1
            emp.Text = "Aucune key."; emp.Font = Enum.Font.Gotham; emp.TextSize = 11
            emp.TextColor3 = Color3.fromRGB(80, 85, 110)
            return
        end
        for _, entry in ipairs(allKeys) do
            local Row = Instance.new("Frame", KeyScroll)
            Row.Size = UDim2.new(1, 0, 0, 36); Row.BackgroundColor3 = Color3.fromRGB(16, 12, 24)
            Row.BorderSizePixel = 0
            Instance.new("UICorner", Row).CornerRadius = UDim.new(0, 6)
            local RSt = Instance.new("UIStroke", Row)
            RSt.Color = entry.isCustom and Color3.fromRGB(80, 180, 80) or Color3.fromRGB(60, 70, 120)
            RSt.Thickness = 1

            local KLbl = Instance.new("TextLabel", Row)
            KLbl.Size = UDim2.new(0.5, 0, 1, 0); KLbl.Position = UDim2.new(0, 8, 0, 0)
            KLbl.BackgroundTransparency = 1; KLbl.Text = entry.key
            KLbl.Font = Enum.Font.GothamBold; KLbl.TextSize = 10
            KLbl.TextColor3 = Color3.fromRGB(220, 220, 255); KLbl.TextXAlignment = Enum.TextXAlignment.Left
            KLbl.TextTruncate = Enum.TextTruncate.AtEnd

            local SLbl = Instance.new("TextLabel", Row)
            SLbl.Size = UDim2.new(0.25, 0, 1, 0); SLbl.Position = UDim2.new(0.5, 0, 0, 0)
            SLbl.BackgroundTransparency = 1; SLbl.Text = entry.status
            SLbl.Font = Enum.Font.GothamBold; SLbl.TextSize = 9
            SLbl.TextColor3 = Color3.fromRGB(100, 200, 140); SLbl.TextXAlignment = Enum.TextXAlignment.Left

            local CopyB = Instance.new("TextButton", Row)
            CopyB.Size = UDim2.new(0, 58, 0, 24); CopyB.Position = UDim2.new(1, -126, 0.5, -12)
            CopyB.BackgroundColor3 = Color3.fromRGB(30, 90, 170); CopyB.Text = "Copier"
            CopyB.Font = Enum.Font.GothamBold; CopyB.TextSize = 10
            CopyB.TextColor3 = Color3.fromRGB(255, 255, 255); CopyB.AutoButtonColor = false
            Instance.new("UICorner", CopyB).CornerRadius = UDim.new(0, 5)
            CopyB.MouseButton1Click:Connect(function()
                copyClip(entry.key)
                CopyB.Text = "Copié!"; CopyB.BackgroundColor3 = Color3.fromRGB(20, 120, 60)
                task.delay(1.5, function() CopyB.Text = "Copier"; CopyB.BackgroundColor3 = Color3.fromRGB(30, 90, 170) end)
            end)
            if entry.isCustom then
                local DelB = Instance.new("TextButton", Row)
                DelB.Size = UDim2.new(0, 58, 0, 24); DelB.Position = UDim2.new(1, -62, 0.5, -12)
                DelB.BackgroundColor3 = Color3.fromRGB(100, 20, 30); DelB.Text = "Suppr."
                DelB.Font = Enum.Font.GothamBold; DelB.TextSize = 10
                DelB.TextColor3 = Color3.fromRGB(255, 255, 255); DelB.AutoButtonColor = false
                Instance.new("UICorner", DelB).CornerRadius = UDim.new(0, 5)
                DelB.MouseButton1Click:Connect(function()
                    local ck = loadCustomKeys(); local nck = {}
                    for _, k in pairs(ck) do
                        local kv = type(k) == "table" and k.key or k
                        if kv ~= entry.key then table.insert(nck, k) end
                    end
                    saveCustomKeys(nck); refreshKeyList()
                end)
            end
        end
    end

    GenBtn.MouseButton1Click:Connect(function()
        local name = KeyNameInput.Text:gsub("%s", "")
        local newKey = name ~= "" and name or genRandKey("Z3US")
        local valid, _ = isKeyValid(newKey)
        if valid then GenStatus.Text = "Key déjà existante!"; GenStatus.TextColor3 = Color3.fromRGB(220, 180, 40); return end
        local ck = loadCustomKeys()
        table.insert(ck, { key = newKey, duration = selectedDuration, createdAt = getCurrentTime() })
        saveCustomKeys(ck); KeyNameInput.Text = ""
        GenStatus.Text = "✔ Créée: "..newKey; GenStatus.TextColor3 = Color3.fromRGB(100, 220, 100)
        copyClip(newKey)
        refreshKeyList()
        notify("Z3US Admin", "Key créée & copiée: "..newKey, 4)
    end)

    LZBtn.MouseButton1Click:Connect(function()
        if LZInput.Text == ADMIN_CODE then
            LoginZone.Visible = false; MainZone.Visible = true
            adminAuthenticated = true; refreshKeyList()
        else
            LZMsg.Text = "Code incorrect."
            TweenService:Create(LZSt2, TweenInfo.new(0.15), { Color = Color3.fromRGB(220, 40, 40) }):Play()
            task.delay(0.8, function()
                TweenService:Create(LZSt2, TweenInfo.new(0.2), { Color = Color3.fromRGB(60, 65, 90) }):Play()
            end)
            task.delay(1.5, function() LZMsg.Text = "" end)
        end
    end)
    if adminAuthenticated then LoginZone.Visible = false; MainZone.Visible = true; refreshKeyList() end

    APFrame.Size = UDim2.new(0, 0, 0, 0); APFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
    TweenService:Create(APFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 660, 0, 600), Position = UDim2.new(0.5, -330, 0.5, -300)
    }):Play()
end

