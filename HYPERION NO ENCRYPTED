        end
        local valid, meta = isKeyValid(key)
        if not valid then
            StatusLbl.Text = "❌ Clé invalide ou expirée."
            StatusLbl.TextColor3 = Color3.fromRGB(220, 80, 80)
            TweenService:Create(ISt, TweenInfo.new(0.1), { Color = Color3.fromRGB(220, 40, 40) }):Play()
