-- WATCHER — vérifie expiration toutes les 10s
-- ============================================================
local createKeyUI  -- déclaration anticipée
local function startWatcher()
    task.spawn(function()
        while true do
            task.wait(10)
            if not isWhitelistValid() then
                clearWhitelist()
                local PlayerGui = Players.LocalPlayer:WaitForChild("PlayerGui")
                if PlayerGui:FindFirstChild("Z3US_MainUI") then
                    PlayerGui:FindFirstChild("Z3US_MainUI"):Destroy()
                end
                notify("Z3US", "Votre key a expiré. Reconnectez-vous.", 4)
                task.wait(1)
                createKeyUI()
                return
            end
        end
    end)
end

