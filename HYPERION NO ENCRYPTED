-- ============================================================
-- UTILITAIRES FICHIERS
-- ============================================================
local function safeRead(file)
    if isfile and isfile(file) then
        local ok, v = pcall(readfile, file)
        return ok and v or nil
    end
    return nil
end
local function safeWrite(file, data) pcall(writefile, file, data) end
local function safeDelete(file)
    pcall(function()
        if isfile and isfile(file) then delfile(file) end
    end)
end
local function loadJSON(file)
    local raw = safeRead(file)
    if not raw then return {} end
    local ok, data = pcall(HttpService.JSONDecode, HttpService, raw)
    return (ok and data) or {}
end
local function saveJSON(file, data)
    local ok, encoded = pcall(HttpService.JSONEncode, HttpService, data)
    if ok then safeWrite(file, encoded) end
end

local function loadWhitelist()   return loadJSON(WHITELIST_FILE) end
local function saveWhitelist(w)  saveJSON(WHITELIST_FILE, w) end
local function loadCustomKeys()  return loadJSON(CUSTOM_KEYS_FILE) end
local function saveCustomKeys(k) saveJSON(CUSTOM_KEYS_FILE, k) end

-- ============================================================
-- TEMPS
-- ============================================================
local function getCurrentTime()
    return os.time and os.time() or 0
end
local function formatTime(seconds)
    if not seconds or seconds <= 0 then return "Expirée" end
    local days  = math.floor(seconds / 86400)
    local hours = math.floor((seconds % 86400) / 3600)
    local mins  = math.floor((seconds % 3600) / 60)
    local secs  = seconds % 60
    if days  > 0 then return days.."j "..hours.."h" end
    if hours > 0 then return hours.."h "..mins.."m" end
    if mins  > 0 then return mins.."m "..secs.."s" end
    return secs.."s"
end

-- ============================================================
-- WHITELIST — stocke { key, activatedAt, duration }
-- ============================================================
local function getWhitelistEntry()
    local wl = loadWhitelist()
    return wl["entry"] or nil
end
local function saveWhitelistEntry(entry)
    local wl = loadWhitelist()
    wl["entry"] = entry
    saveWhitelist(wl)
end
local function clearWhitelist()
    safeDelete(WHITELIST_FILE)
end

local function isWhitelistValid()
    local entry = getWhitelistEntry()
    if not entry then return false end
    local duration    = tonumber(entry.duration)
    local activatedAt = tonumber(entry.activatedAt) or 0
    if not duration or duration >= 999999999 then return true end
    return getCurrentTime() < (activatedAt + duration)
end

local function getWhitelistRemaining()
    local entry = getWhitelistEntry()
    if not entry then return "—" end
    local duration    = tonumber(entry.duration)
    local activatedAt = tonumber(entry.activatedAt) or 0
    if not duration or duration >= 999999999 then return "Illimitée" end
    return formatTime(math.max((activatedAt + duration) - getCurrentTime(), 0))
end

-- ============================================================
-- VALIDATION KEYS
-- ============================================================
local function getCustomKeyMeta(targetKey)
    for _, entry in pairs(loadCustomKeys()) do
        if type(entry) == "table" and entry.key == targetKey then return entry end
        if type(entry) == "string" and entry == targetKey then
            return { key = entry, duration = 999999999, createdAt = 0 }
        end
    end
    return nil
end

local function isKeyValid(key)
    if not key or key == "" then return false, nil end
    for _, k in pairs(VALID_KEYS) do
        if key == k then return true, { duration = 999999999 } end
    end
    local customKeys = loadCustomKeys()
    for _, entry in pairs(customKeys) do
        if type(entry) == "string" then
            if key == entry then return true, { duration = 999999999 } end
        elseif type(entry) == "table" and entry.key == key then
            local duration  = tonumber(entry.duration)
            local createdAt = tonumber(entry.createdAt) or 0
            if not duration or duration >= 999999999 then
                return true, entry
            end
            if getCurrentTime() <= (createdAt + duration) then
                return true, entry
            else
                return false, nil -- key expirée
            end
        end
    end
    return false, nil
end

