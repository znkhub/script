    }):Play()
end

-- ============================================================
-- POINT D'ENTRÉE
-- ============================================================
local function isAdmin(userId)
    for _, id in ipairs(ADMIN_IDS) do if id == userId then return true end end
    return false
end

if isAdmin(Players.LocalPlayer.UserId) then
    adminAuthenticated = true
    openAdminPanel()
elseif isWhitelistValid() then
    -- Déjà whitelisté → on lance directement sans UI
    notify("Z3US", "Session active — Lancement direct ⚡", 3)
    startWatcher()
    launchRivals()
else
    clearWhitelist()
    createKeyUI()
end

Players.LocalPlayer.Chatted:Connect(function(msg)
    if msg:lower() == "/admin" and isAdmin(Players.LocalPlayer.UserId) then
        openAdminPanel()
    end
end)
