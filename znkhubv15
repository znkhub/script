-- SYSTÈME DE SAUVEGARDE
-- ========================================
 
local SAVE_FILE = "znk_v5_save.json"
 
local function saveFullConfig()
    pcall(function()
        local toSave = {}
        for k, v in pairs(settings) do
            if type(v) == "Color3" then
                toSave[k] = {r = v.R, g = v.G, b = v.B, _isColor = true}
            else
                toSave[k] = v
            end
        end
        writefile(SAVE_FILE, HttpService:JSONEncode(toSave))
    end)
end
 
local function applyLoadedSettings()
    if not (isfile and isfile(SAVE_FILE)) then return false end
    local ok, data = pcall(function() return HttpService:JSONDecode(readfile(SAVE_FILE)) end)
    if not ok or not data then return false end
 
    for k, v in pairs(data) do
        if type(v) == "table" and v._isColor then
            settings[k] = Color3.new(v.r, v.g, v.b)
        else
            settings[k] = v
        end
    end
 
    if LANGUAGE_NAMES[settings.language] then
        currentLang = settings.language
        refreshAllLabels()
    end
    local loadedHideKeyOk = false
    pcall(function()
        loadedHideKeyOk = settings.hideKey and Enum.KeyCode[settings.hideKey] ~= nil
    end)
    if not loadedHideKeyOk then
        settings.hideKey = "RightControl"
    end
    if keybindButton then
        keybindButton.Text = settings.hideKey
    end
 
    if settings.speedEnabled and humanoid then
        humanoid.WalkSpeed = settings.walkSpeed
    end
    if humanoid then
        humanoid.JumpPower = settings.jumpPower
    end
    if settings.fovChanger then
        camera.FieldOfView = settings.fovValue
    end
    if settings.fullbright then
        local L = game:GetService("Lighting")
        L.Brightness = 2; L.ClockTime = 14; L.FogEnd = 100000
        L.GlobalShadows = false; L.OutdoorAmbient = Color3.fromRGB(128,128,128)
    end
    if settings.noFog then
        local L = game:GetService("Lighting")
        L.FogEnd = 100000
        for _, v in pairs(L:GetChildren()) do
            if v:IsA("Atmosphere") then v.Density = 0 end
        end
    end
    if settings.thirdPerson then
        player.CameraMode = Enum.CameraMode.Classic
        player.CameraMinZoomDistance = 5
    end
 
    syncToggleStates()
    saveSettings()
    return true
end
 
