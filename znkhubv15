-- ========================================
-- FONCTIONS UTILITAIRES JSON
-- ========================================
local function readJSON(file)
    if isfile and isfile(file) then
        local ok, data = pcall(function()
            return HttpService_:JSONDecode(readfile(file))
        end)
        if ok and data then return data end
    end
    return {}
end
 
local function writeJSON(file, data)
    pcall(function()
        writefile(file, HttpService_:JSONEncode(data))
    end)
end
 
local function getKeysDB()
    local db = readJSON(KEYS_FILE)
    if not db.keys then db.keys = {} end
    return db
end
 
local function saveKeysDB(db)
    writeJSON(KEYS_FILE, db)
end
 
local function getWhitelist()
    local wl = readJSON(WHITELIST_FILE)
    if not wl.entries then wl.entries = {} end
    return wl
end
 
local function saveWhitelist(wl)
    writeJSON(WHITELIST_FILE, wl)
end
 
local function cleanExpiredWhitelist()
    local wl = getWhitelist()
    local now = os.time()
    local changed = false
    for k, entry in pairs(wl.entries) do
        if entry.expiresAt and entry.expiresAt <= now then
            wl.entries[k] = nil
            changed = true
        end
    end
    if changed then saveWhitelist(wl) end
    return wl
end
 
local function isKeyWhitelisted(key)
    local wl = cleanExpiredWhitelist()
    local entry = wl.entries[key]
    if entry and entry.expiresAt and os.time() < entry.expiresAt then
        return true, entry.expiresAt - os.time()
    end
    return false, 0
end
 
local function findKeyInDB(keyStr)
    local db = getKeysDB()
    for _, k in ipairs(db.keys) do
        if k.key == keyStr then return k end
    end
    return nil
end
 
local function activateKey(keyStr)
    local db = getKeysDB()
    for i, k in ipairs(db.keys) do
        if k.key == keyStr then
            local wl = getWhitelist()
            wl.entries[keyStr] = {
                activatedAt = os.time(),
                expiresAt = os.time() + k.duration,
                duration = k.duration,
            }
            saveWhitelist(wl)
            db.keys[i].usedAt = os.time()
            db.keys[i].usedBy = tostring(Players.LocalPlayer.UserId)
            saveKeysDB(db)
            return true, k.duration
        end
    end
    return false, 0
end
 
local function generateKey(prefix)
    prefix = prefix or "ZNK"
    local chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local result = prefix .. "-"
    for i = 1, 4 do
        local idx = math.random(1, #chars)
        result = result .. string.sub(chars, idx, idx)
    end
    result = result .. "-"
    for i = 1, 4 do
        local idx = math.random(1, #chars)
        result = result .. string.sub(chars, idx, idx)
    end
    return result
end
 
local function formatTime(seconds)
    if seconds <= 0 then return "Expirée" end
    local days = math.floor(seconds / 86400)
    local hours = math.floor((seconds % 86400) / 3600)
    local mins = math.floor((seconds % 3600) / 60)
    local secs = seconds % 60
    if days > 0 then return days .. "j " .. hours .. "h" end
    if hours > 0 then return hours .. "h " .. mins .. "m" end
    if mins > 0 then return mins .. "m " .. secs .. "s" end
    return secs .. "s"
end
 
