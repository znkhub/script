local toggleRegistry = {}
 
local function paintToggle(record, enabled, instant)
    record.enabled = enabled
    local knobPos = enabled and UDim2.new(1, -19, 0.5, -8.5) or UDim2.new(0, 2, 0.5, -8.5)
    local bg = enabled and currentTheme or Color3.fromRGB(45, 45, 55)
    if instant then
        record.button.BackgroundColor3 = bg
        record.circle.Position = knobPos
    else
        TweenService:Create(record.button, TweenInfo.new(0.2), {BackgroundColor3 = bg}):Play()
        TweenService:Create(record.circle, TweenInfo.new(0.2), {Position = knobPos}):Play()
    end
end
 
local function syncToggleStates()
    for _, records in pairs(toggleRegistry) do
        for _, record in ipairs(records) do
            if record.settingKey and type(settings[record.settingKey]) == "boolean" and record.enabled ~= settings[record.settingKey] then
                paintToggle(record, settings[record.settingKey], false)
            end
        end
    end
end
 
local function setToggleState(record, enabled, runCallback)
    paintToggle(record, enabled, false)
    if runCallback then
        record.callback(enabled)
        syncToggleStates()
    end
end
 
local function findToggleBySetting(settingKey)
    for _, records in pairs(toggleRegistry) do
        for _, record in ipairs(records) do
            if record.settingKey == settingKey then
                return record
            end
        end
    end
end
 
local function setToggleBySetting(settingKey, enabled, runCallback)
    local record = findToggleBySetting(settingKey)
    if record then
        if record.enabled ~= enabled or runCallback then
            setToggleState(record, enabled, runCallback)
        end
    else
        settings[settingKey] = enabled
    end
end
 
local function invertTabToggles(tabName)
    local records = toggleRegistry[tabName] or {}
    if #records == 0 then return end
    for _, record in ipairs(records) do
        setToggleState(record, not record.enabled, true)
    end
    saveSettings()
    notify("ZNK Invert", T("btn_invert") .. " - " .. tabName, 2)
end
 
