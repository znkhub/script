local function saveSettings()
    pcall(function()
        local toSave = {}
        for k, v in pairs(settings) do
            if type(v) == "Color3" then
                toSave[k] = {r=v.R, g=v.G, b=v.B}
            else
                toSave[k] = v
            end
        end
        writefile("znk_v4_config.json", HttpService:JSONEncode(toSave))
    end)
end
 
local function loadSettings()
    if isfile and isfile("znk_v4_config.json") then
        local ok, data = pcall(function() return HttpService:JSONDecode(readfile("znk_v4_config.json")) end)
        if ok and data then
            for k, v in pairs(data) do
                if type(v) == "table" and v.r ~= nil then
                    settings[k] = Color3.new(v.r, v.g, v.b)
                else
                    settings[k] = v
                end
            end
        end
    end
end
 
