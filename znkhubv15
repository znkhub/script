local function createSlider(tabName, textKey, min, max, default, suffix, callback)
    local Slider = Instance.new("Frame")
    Slider.Size = UDim2.new(1, 0, 0, 58)
    Slider.BackgroundColor3 = panelSoft
    Slider.BorderSizePixel = 0
    Slider.Visible = (tabName == currentTab)
    Slider.Parent = Content
    Instance.new("UICorner", Slider).CornerRadius = UDim.new(0, 8)
    table.insert(tabPages[tabName], Slider)
 
    local Label = Instance.new("TextLabel", Slider)
    Label.Size = UDim2.new(0.65, 0, 0, 18); Label.Position = UDim2.new(0, 12, 0, 8)
    Label.BackgroundTransparency = 1; Label.Text = T(textKey)
    Label.Font = Enum.Font.GothamBold; Label.TextSize = 13
    Label.TextColor3 = Color3.fromRGB(238, 236, 242); Label.TextXAlignment = Enum.TextXAlignment.Left
    table.insert(dynamicLabels, {elem = Label, key = textKey})
 
    local ValueBox = Instance.new("TextLabel", Slider)
    ValueBox.Size = UDim2.new(0, 52, 0, 18); ValueBox.Position = UDim2.new(1, -60, 0, 8)
    ValueBox.BackgroundColor3 = Color3.fromRGB(34, 26, 43)
    ValueBox.Text = tostring(default) .. (suffix or "")
    ValueBox.Font = Enum.Font.GothamBold; ValueBox.TextSize = 11; ValueBox.TextColor3 = currentTheme
    Instance.new("UICorner", ValueBox).CornerRadius = UDim.new(0, 5)
 
    local Track = Instance.new("Frame", Slider)
    Track.Size = UDim2.new(1, -24, 0, 5); Track.Position = UDim2.new(0, 12, 1, -16)
    Track.BackgroundColor3 = Color3.fromRGB(48, 45, 55); Track.BorderSizePixel = 0
    Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)
 
    local Fill = Instance.new("Frame", Track)
    Fill.Size = UDim2.new((default-min)/(max-min), 0, 1, 0)
    Fill.BackgroundColor3 = currentTheme; Fill.BorderSizePixel = 0
    Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)
 
    local Thumb = Instance.new("Frame", Track)
    Thumb.Size = UDim2.new(0, 12, 0, 12)
    Thumb.Position = UDim2.new((default-min)/(max-min), -6, 0.5, -6)
    Thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255); Thumb.BorderSizePixel = 0
    Instance.new("UICorner", Thumb).CornerRadius = UDim.new(1, 0)
 
    local dragging = false
    local function update(val)
        val = math.clamp(math.floor(val), min, max)
        local p = (val-min)/(max-min)
        Fill.Size = UDim2.new(p, 0, 1, 0)
        Thumb.Position = UDim2.new(p, -6, 0.5, -6)
        ValueBox.Text = tostring(val) .. (suffix or "")
        callback(val)
    end
 
    Track.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update(min + math.clamp((inp.Position.X - Track.AbsolutePosition.X)/Track.AbsoluteSize.X,0,1)*(max-min))
        end
    end)
    Track.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            update(min + math.clamp((inp.Position.X - Track.AbsolutePosition.X)/Track.AbsoluteSize.X,0,1)*(max-min))
        end
    end)
    return Slider
end
 
