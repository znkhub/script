    AdminBtnLogin.TextColor3 = Color3.fromRGB(180,120,30); AdminBtnLogin.AutoButtonColor = false; AdminBtnLogin.BorderSizePixel = 0
    Instance.new("UICorner", AdminBtnLogin).CornerRadius = UDim.new(0,7)
    local AdminBtnLoginStroke = Instance.new("UIStroke", AdminBtnLogin)
    AdminBtnLoginStroke.Color = Color3.fromRGB(255,160,20); AdminBtnLoginStroke.Thickness = 1; AdminBtnLoginStroke.Transparency = 0.5
    AdminBtnLogin.MouseButton1Click:Connect(function()
        openAdminPanel()
    end)
 
    local InfoLabel = Instance.new("TextLabel", LoginFrame)
    InfoLabel.Size = UDim2.new(1, -140, 0, 16); InfoLabel.Position = UDim2.new(0, 20, 1, -38)
    InfoLabel.BackgroundTransparency = 1; InfoLabel.Text = "🔑 Keys disponibles sur le Discord ZNK"
    InfoLabel.Font = Enum.Font.Gotham; InfoLabel.TextSize = 11
    InfoLabel.TextColor3 = Color3.fromRGB(80, 110, 170); InfoLabel.TextXAlignment = Enum.TextXAlignment.Left
 
    local loginAttempts = 0
    local loginLocked = false
 
    local function animateShake()
        for i = 1, 6 do
            TweenService_:Create(LoginFrame, TweenInfo.new(0.05), {
                Position = UDim2.new(0.5, -230 + (i % 2 == 0 and 8 or -8), 0.5, -260)
            }):Play()
            task.wait(0.05)
        end
        TweenService_:Create(LoginFrame, TweenInfo.new(0.1), {Position = UDim2.new(0.5, -230, 0.5, -260)}):Play()
    end
 
    local function doLogin()
        if loginLocked then return end
        local username = UsernameInput.Text:gsub("%s", "")
        local password = PasswordInput.Text
        local key = KeyInput.Text:gsub("%s", "")
 
        if username == "" or password == "" then
            StatusMsg.Text = "❌ Pseudo et mot de passe requis"
            StatusMsg.TextColor3 = Color3.fromRGB(220, 80, 80)
            animateShake(); return
        end
 
        if accountExists(username) then
            local ok, _ = checkAccount(username, password)
            if ok then
                StatusMsg.Text = "✅ Connexion réussie ! Chargement..."
                StatusMsg.TextColor3 = Color3.fromRGB(50, 200, 100)
                loggedUsername = username
                if key ~= "" and isKeyValid(key) then
                    pcall(function() writefile(KEY_FILE, key) end)
                end
                TweenService_:Create(LoginFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
                    Size = UDim2.new(0,0,0,0), Position = UDim2.new(0.5,0,0.5,0)
                }):Play()
                task.wait(0.5); LoginGui:Destroy(); loginVerified = true; return
            else
                loginAttempts = loginAttempts + 1
                StatusMsg.Text = "❌ Mot de passe incorrect"
                StatusMsg.TextColor3 = Color3.fromRGB(220, 80, 80)
                animateShake(); return
            end
        end
 
        if key ~= "" and isKeyValid(key) then
            saveAccount(username, password, key)
            pcall(function() writefile(KEY_FILE, key) end)
            StatusMsg.Text = "✅ Compte créé & connecté ! Chargement..."
            StatusMsg.TextColor3 = Color3.fromRGB(50, 200, 100)
            loggedUsername = username
            TweenService_:Create(LoginFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
                Size = UDim2.new(0,0,0,0), Position = UDim2.new(0.5,0,0.5,0)
            }):Play()
            task.wait(0.5); LoginGui:Destroy(); loginVerified = true; return
        end
 
        loginAttempts = loginAttempts + 1
        StatusMsg.Text = "❌ Compte inconnu. Utilisez une key pour créer un compte."
        StatusMsg.TextColor3 = Color3.fromRGB(220, 80, 80)
        animateShake()
    end
 
    local function doRegister()
        if loginLocked then return end
        local username = UsernameInput.Text:gsub("%s", "")
        local password = PasswordInput.Text
        local key = KeyInput.Text:gsub("%s", "")
 
        if username == "" or password == "" then
            StatusMsg.Text = "❌ Pseudo et mot de passe requis"
            StatusMsg.TextColor3 = Color3.fromRGB(220, 80, 80)
            animateShake(); return
        end
        if #username < 3 then
            StatusMsg.Text = "❌ Pseudo trop court (min 3 caractères)"
            StatusMsg.TextColor3 = Color3.fromRGB(220, 80, 80)
            animateShake(); return
        end
        if #password < 4 then
            StatusMsg.Text = "❌ Mot de passe trop court (min 4 caractères)"
            StatusMsg.TextColor3 = Color3.fromRGB(220, 80, 80)
            animateShake(); return
        end
        if accountExists(username) then
            StatusMsg.Text = "❌ Ce pseudo est déjà pris !"
            StatusMsg.TextColor3 = Color3.fromRGB(220, 80, 80)
            animateShake(); return
        end
        if not isKeyValid(key) then
            StatusMsg.Text = "❌ Key invalide ! Requis pour l'inscription."
            StatusMsg.TextColor3 = Color3.fromRGB(220, 80, 80)
            TweenService_:Create(KeyStroke, TweenInfo.new(0.15), {Color = Color3.fromRGB(220, 40, 40)}):Play()
            animateShake()
            task.delay(0.5, function()
                TweenService_:Create(KeyStroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(70, 55, 85)}):Play()
            end)
            return
        end
 
        saveAccount(username, password, key)
        pcall(function() writefile(KEY_FILE, key) end)
        StatusMsg.Text = "✅ Compte créé ! Chargement..."
        StatusMsg.TextColor3 = Color3.fromRGB(50, 200, 100)
        loggedUsername = username
        TweenService_:Create(LoginFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
            Size = UDim2.new(0,0,0,0), Position = UDim2.new(0.5,0,0.5,0)
        }):Play()
        task.wait(0.5); LoginGui:Destroy(); loginVerified = true
    end
 
    LoginBtn.MouseButton1Click:Connect(doLogin)
    RegisterBtn.MouseButton1Click:Connect(doRegister)
 
    LoginFrame.Size = UDim2.new(0, 0, 0, 0)
    LoginFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
    TweenService_:Create(LoginFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 460, 0, 520),
        Position = UDim2.new(0.5, -230, 0.5, -260)
    }):Play()
 
    repeat task.wait(0.1) until loginVerified or not LoginGui.Parent
    if not loginVerified then return end
end
 
