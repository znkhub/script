    local function generateRandomKey(prefix)
        prefix = prefix or "ZNK"
        local chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
        local result = prefix .. "-"
        for i = 1, 4 do result = result .. string.sub(chars, math.random(1,#chars), math.random(1,#chars)) end
        result = result .. "-"
        for i = 1, 4 do result = result .. string.sub(chars, math.random(1,#chars), math.random(1,#chars)) end
        return result
    end
 
    local function refreshKeyList()
        for _, child in pairs(KeyListScroll:GetChildren()) do
            if child:IsA("Frame") then child:Destroy() end
        end
 
        local allKeys = {}
        for _, k in pairs(VALID_KEYS) do
            table.insert(allKeys, {key=k, isCustom=false, duration=nil})
        end
        local customKeys = loadCustomKeys()
        for _, entry in pairs(customKeys) do
            if type(entry) == "table" then
                table.insert(allKeys, {key=entry.key, isCustom=true, duration=entry.duration, createdAt=entry.createdAt})
            elseif type(entry) == "string" then
                table.insert(allKeys, {key=entry, isCustom=true, duration=nil})
            end
        end
 
        if #allKeys == 0 then
            local NoKey = Instance.new("TextLabel", KeyListScroll)
            NoKey.Size = UDim2.new(1,0,0,28); NoKey.BackgroundTransparency = 1
            NoKey.Text = "Aucune key."; NoKey.Font = Enum.Font.Gotham; NoKey.TextSize = 11
            NoKey.TextColor3 = Color3.fromRGB(120,110,140)
            return
