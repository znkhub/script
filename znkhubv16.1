        for k, v in pairs(settings) do
            if type(v)=="Color3" then toSave[k]={r=v.R,g=v.G,b=v.B} else toSave[k]=v end
        end
        writefile("znk_v4_config.json", HttpService:JSONEncode(toSave))
    end)
end
 
