                else
                    DelBtn.BackgroundColor3=Color3.fromRGB(120,20,20); DelBtn.TextColor3=Color3.fromRGB(255,100,100)
                    DelBtn.MouseButton1Click:Connect(function()
                        table.remove(wlData,i); saveWhitelist(wlData); rebuildRows(); updateCount()
                        notify("Admin","🗑️ Clé supprimée : "..entry.key,3)
                    end)
                end
            end
            updateCount()
        end

        -- Générer une key aléatoire
        local function generateKey()
            local chars="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
            local function rnd(n) local s="" for _=1,n do s=s..chars:sub(math.random(1,#chars),math.random(1,#chars)) end return s end
            return "ZNK-"..rnd(4).."-"..rnd(4).."-"..rnd(4)
        end

        local function addKey(k)
            k=k:match("^%s*(.-)%s*$")
            if k=="" then notify("Admin","⚠️ Clé vide !",2); return end
            for _,e in ipairs(wlData) do if e.key==k then notify("Admin","⚠️ Clé déjà existante !",2); return end end
            local expiry=selectedDur==-1 and -1 or (os.time()+selectedDur)
            table.insert(wlData,{key=k, pid="", expiry=expiry})
            saveWhitelist(wlData); rebuildRows(); updateCount()
            local durTxt=selectedDur==-1 and "permanente" or ("valable "..formatTime(selectedDur))
            notify("Admin","✅ Clé ajoutée ("..durTxt..") : "..k,3)
            NKBox.Text=""
        end

        AddBtn.MouseButton1Click:Connect(function() addKey(NKBox.Text) end)
        GenBtn.MouseButton1Click:Connect(function()
            local nk=generateKey(); NKBox.Text=nk
            notify("Admin","✦ Clé générée : "..nk,3)
        end)

        -- S'assurer que la key admin est toujours dans la whitelist
        local adminFound=false
        for _,e in ipairs(wlData) do if e.key==ADMIN_CODE then adminFound=true; break end end
        if not adminFound then
            table.insert(wlData,{key=ADMIN_CODE, pid="", expiry=-1})
            saveWhitelist(wlData)
        end

        rebuildRows()

        AP.Size=UDim2.new(0,0,0,0); AP.Position=UDim2.new(0.5,0,0.5,0)
        TweenService:Create(AP,TweenInfo.new(0.5,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{
