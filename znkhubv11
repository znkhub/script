-- { ip = "...", key = "...", expiry = os.time() + duree_en_secondes }
-- Les keys valides et leur durée sont gérées dans le panel admin
-- Format fichier whitelist : JSON array de { key, ip, expiry }

local WHITELIST_FILE = "znk_whitelist.json"
local SESSION_FILE   = "znk_session.json"

-- Récupère l'IP locale du joueur (identifiant unique basé sur UserId en Roblox)
-- En Roblox on ne peut pas avoir la vraie IP, on utilise le UserId comme identifiant unique
local function getPlayerID()
    return tostring(player.UserId)
end

-- Lire la whitelist
local function loadWhitelist()
    if isfile and isfile(WHITELIST_FILE) then
        local ok, data = pcall(function()
            return HttpService:JSONDecode(readfile(WHITELIST_FILE))
        end)
        if ok and type(data) == "table" then return data end
    end
    return {}
end

-- Sauvegarder la whitelist
local function saveWhitelist(wl)
    pcall(function()
        writefile(WHITELIST_FILE, HttpService:JSONEncode(wl))
    end)
end

-- Charger la session locale
local function loadSession()
    if isfile and isfile(SESSION_FILE) then
        local ok, data = pcall(function()
            return HttpService:JSONDecode(readfile(SESSION_FILE))
        end)
        if ok and type(data) == "table" then return data end
    end
    return nil
end

-- Sauvegarder la session locale
local function saveSession(key, expiry)
    pcall(function()
        writefile(SESSION_FILE, HttpService:JSONEncode({
            key = key,
            pid = getPlayerID(),
            expiry = expiry
        }))
    end)
end

-- Supprimer la session locale
local function clearSession()
    pcall(function()
        if isfile and isfile(SESSION_FILE) then
            writefile(SESSION_FILE, "{}")
        end
    end)
end

-- Formater le temps restant
local function formatTime(seconds)
    if seconds <= 0 then return "Expirée" end
    local h = math.floor(seconds / 3600)
    local m = math.floor((seconds % 3600) / 60)
    local s = math.floor(seconds % 60)
    if h > 0 then
        return string.format("%dh %02dm %02ds", h, m, s)
    elseif m > 0 then
        return string.format("%dm %02ds", m, s)
    else
        return string.format("%ds", s)
    end
end

-- Vérifier si une key est valide pour ce joueur
local function checkKeyForPlayer(key)
    local wl = loadWhitelist()
    local pid = getPlayerID()
    local now = os.time()

    for i, entry in ipairs(wl) do
        if entry.key == key then
            -- Key trouvée
            if entry.expiry ~= -1 and now > entry.expiry then
                -- Expirée : on supprime
                table.remove(wl, i)
                saveWhitelist(wl)
                return false, "expired"
            end
            -- Vérifier si déjà whitelistée à un autre joueur
            if entry.pid ~= nil and entry.pid ~= "" and entry.pid ~= pid then
                return false, "wrongip"
            end
            -- Whitelister ce joueur si pas encore fait
            if entry.pid == nil or entry.pid == "" then
                wl[i].pid = pid
                saveWhitelist(wl)
            end
            return true, entry.expiry
        end
    end
    return false, "invalid"
end

-- Vérifier la session sauvegardée
local function checkSavedSession()
    local session = loadSession()
    if not session or not session.key then return false end
    if session.pid ~= getPlayerID() then return false end

    local now = os.time()
    -- Vérifier aussi dans la whitelist
    local valid, result = checkKeyForPlayer(session.key)
    if valid then
        if result == -1 then return true, -1 end
        if now <= result then return true, result end
    end
    clearSession()
    return false
end

