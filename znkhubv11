    end

    CConf.MouseButton1Click:Connect(function()
        local entered=CBox.Text:match("^%s*(.-)%s*$")
        TweenService:Create(CConf,TweenInfo.new(0.07),{Size=UDim2.new(1,-26,0,36)}):Play()
