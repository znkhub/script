            CFS.Color=Color3.fromRGB(80,220,120); task.wait(0.6); openAdminPanel()
        else
            CStat.Text="❌ Code incorrect."; CStat.TextColor3=Color3.fromRGB(220,60,60)
            CFS.Color=Color3.fromRGB(220,60,60); shakeCodeFrame(); CBox.Text=""
            task.delay(0.5,function() TweenService:Create(CFS,TweenInfo.new(0.2),{Color=Color3.fromRGB(255,180,0)}):Play() end)
        end
    end)
end)

