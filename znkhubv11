                TimeLbl.TextColor3=entry.expiry==-1 and Color3.fromRGB(80,180,255) or (now>entry.expiry and Color3.fromRGB(220,60,60) or Color3.fromRGB(80,220,120))
                TimeLbl.TextXAlignment=Enum.TextXAlignment.Left

                -- Badge ADMIN
                if entry.key==ADMIN_CODE then
                    local Bdg=Instance.new("TextLabel",Row); Bdg.Size=UDim2.new(0,46,0,16); Bdg.Position=UDim2.new(1,-222,0,2); Bdg.BackgroundColor3=Color3.fromRGB(80,50,0); Bdg.Text="ADMIN"; Bdg.Font=Enum.Font.GothamBold; Bdg.TextSize=10; Bdg.TextColor3=Color3.fromRGB(255,210,60)
                    Instance.new("UICorner",Bdg).CornerRadius=UDim.new(0,5)
                end

                -- Bouton Copier
                local CpBtn=Instance.new("TextButton",Row); CpBtn.Size=UDim2.new(0,64,0,28); CpBtn.Position=UDim2.new(1,-154,0.5,-14)
                CpBtn.BackgroundColor3=Color3.fromRGB(20,50,120); CpBtn.Text="📋 Copier"; CpBtn.Font=Enum.Font.GothamBold; CpBtn.TextSize=11; CpBtn.TextColor3=Color3.fromRGB(150,190,255); CpBtn.AutoButtonColor=false
