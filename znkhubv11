                KL2.TextXAlignment=Enum.TextXAlignment.Left

                -- Info joueur
                local PIL=Instance.new("TextLabel",Row); PIL.Size=UDim2.new(1,-230,0,16); PIL.Position=UDim2.new(0,32,0,28); PIL.BackgroundTransparency=1
