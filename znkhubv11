                -- N°
                local NL=Instance.new("TextLabel",Row); NL.Size=UDim2.new(0,22,0,20); NL.Position=UDim2.new(0,8,0,6); NL.BackgroundTransparency=1; NL.Text=tostring(i); NL.Font=Enum.Font.GothamBold; NL.TextSize=11; NL.TextColor3=Color3.fromRGB(100,120,180)

                -- Clé
                local KL2=Instance.new("TextLabel",Row); KL2.Size=UDim2.new(1,-230,0,20); KL2.Position=UDim2.new(0,32,0,6); KL2.BackgroundTransparency=1
