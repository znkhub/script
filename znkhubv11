createToggle("Wallhack","Red ESP",settings.redESP,function(enabled)
    settings.redESP=enabled
    if enabled then
        settings.rainbowESP=false; notify("Wallhack","Red ESP activé",2)
        local function addESP(plr)
            if plr==player then return end
            local function onChar(char) task.wait(0.1); if not char then return end
                if highlights[plr] then pcall(function() highlights[plr]:Destroy() end) end
                local hl=Instance.new("Highlight"); hl.Adornee=char
                hl.FillColor=settings.espColor; hl.OutlineColor=settings.espColor
                hl.FillTransparency=settings.espTransparency; hl.OutlineTransparency=0
                hl.Parent=char; highlights[plr]=hl end
            if plr.Character then onChar(plr.Character) end
            plr.CharacterAdded:Connect(onChar)
        end
        for _,p in pairs(Players:GetPlayers()) do addESP(p) end
        table.insert(connections,Players.PlayerAdded:Connect(addESP))
    else for _,h in pairs(highlights) do pcall(function() h:Destroy() end) end; highlights={} end
