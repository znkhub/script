                    task.delay(1.5,function() CpBtn.Text="📋 Copier"; CpBtn.TextColor3=Color3.fromRGB(150,190,255) end)
                end)

                -- Bouton Reset IP
                local RstBtn=Instance.new("TextButton",Row); RstBtn.Size=UDim2.new(0,64,0,28); RstBtn.Position=UDim2.new(1,-84,0.5,-14)
                RstBtn.Text="🔄 Reset"; RstBtn.Font=Enum.Font.GothamBold; RstBtn.TextSize=11; RstBtn.AutoButtonColor=false
                Instance.new("UICorner",RstBtn).CornerRadius=UDim.new(0,6)
                if entry.key==ADMIN_CODE then
                    RstBtn.BackgroundColor3=Color3.fromRGB(30,30,30); RstBtn.TextColor3=Color3.fromRGB(70,70,70)
                else
                    RstBtn.BackgroundColor3=Color3.fromRGB(50,30,10); RstBtn.TextColor3=Color3.fromRGB(255,160,60)
                    RstBtn.MouseButton1Click:Connect(function()
                        wlData[i].pid=""; PIL.Text="👤 Non utilisée"
                        saveWhitelist(wlData); notify("Admin","🔄 IP réinitialisée pour : "..entry.key,3)
                    end)
                end

                -- Bouton Révoquer
                local RvBtn=Instance.new("TextButton",Row); RvBtn.Size=UDim2.new(0,0,0,0); RvBtn.Visible=false -- caché, on garde Reset + Copier

                -- On ajoute un bouton supprimer séparé à droite du frame (invisible pour admin key)
                local DelBtn=Instance.new("TextButton",Row); DelBtn.Size=UDim2.new(0,14,0,14); DelBtn.Position=UDim2.new(1,-16,0,4)
                DelBtn.Text="✕"; DelBtn.Font=Enum.Font.GothamBold; DelBtn.TextSize=10; DelBtn.AutoButtonColor=false; DelBtn.BorderSizePixel=0
                Instance.new("UICorner",DelBtn).CornerRadius=UDim.new(1,0)
                if entry.key==ADMIN_CODE then
