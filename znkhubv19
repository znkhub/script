            if not settings.fly or not rootpart or not rootpart.Parent then if flyConnection then flyConnection:Disconnect(); flyConnection=nil end return end
            local dir=Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W)         then dir=dir+camera.CFrame.LookVector end
