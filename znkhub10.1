            local chars="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
            local function rand(n)
                local s=""
                for _=1,n do
                    local r=math.random(1,#chars)
                    s=s..chars:sub(r,r)
                end
                return s
            end
            return "ZNK-"..rand(4).."-"..rand(4).."-"..rand(4)
        end

