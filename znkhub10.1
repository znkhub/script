    -- Logique bouton
    local attempts = 0
    local locked = false

    -- Shake helper
    local function shake()
        for i = 1, 6 do
            local ox = (i % 2 == 0) and 8 or -8
            TweenService:Create(KFrame, TweenInfo.new(0.045), {
                Position = UDim2.new(0.5,-210+ox,0.5,-150)
            }):Play()
            task.wait(0.05)
        end
        TweenService:Create(KFrame, TweenInfo.new(0.1), {
            Position = UDim2.new(0.5,-210,0.5,-150)
        }):Play()
    end

    ConfirmBtn.MouseButton1Click:Connect(function()
        if locked then return end
        local entered = KeyInput.Text:match("^%s*(.-)%s*$") -- trim

        -- Animation clic
        TweenService:Create(ConfirmBtn, TweenInfo.new(0.07), {Size=UDim2.new(1,-42,0,38)}):Play()
        task.wait(0.07)
        TweenService:Create(ConfirmBtn, TweenInfo.new(0.07), {Size=UDim2.new(1,-40,0,40)}):Play()

        if isKeyValid(entered) then
            -- Succès
            StatusLbl.Text = "✅ Clé valide ! Chargement..."
            StatusLbl.TextColor3 = Color3.fromRGB(50,210,100)
            KStroke.Color = Color3.fromRGB(50,210,100)
            IStroke.Color = Color3.fromRGB(50,210,100)
            ConfirmBtn.BackgroundColor3 = Color3.fromRGB(25,150,70)
            saveKey(entered)
            task.wait(1.2)
            TweenService:Create(KFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
                Size = UDim2.new(0,0,0,0),
                Position = UDim2.new(0.5,0,0.5,0)
            }):Play()
            task.wait(0.45)
            KeyGui:Destroy()
            keyVerified = true
        else
            -- Échec
            attempts += 1
            KStroke.Color = Color3.fromRGB(220,40,40)
            IStroke.Color = Color3.fromRGB(220,40,40)
            shake()

            if attempts >= 3 then
                locked = true
                StatusLbl.Text = "🚫 Trop de tentatives. Relancez le script."
                StatusLbl.TextColor3 = Color3.fromRGB(220,40,40)
                ConfirmBtn.BackgroundColor3 = Color3.fromRGB(80,20,20)
                ConfirmBtn.Text = "BLOQUÉ"
                KeyInput.Editable = false
            else
                local remaining = 3 - attempts
                StatusLbl.Text = "❌ Clé incorrecte — " .. remaining .. " essai(s) restant(s)"
                StatusLbl.TextColor3 = Color3.fromRGB(220,80,80)
                KeyInput.Text = ""
                task.delay(0.6, function()
                    TweenService:Create(KStroke, TweenInfo.new(0.2), {Color=Color3.fromRGB(30,100,255)}):Play()
                    TweenService:Create(IStroke, TweenInfo.new(0.2), {Color=Color3.fromRGB(30,70,160)}):Play()
                end)
            end
        end
    end)

    -- Animation d'entrée
    KFrame.Size = UDim2.new(0,0,0,0)
    KFrame.Position = UDim2.new(0.5,0,0.5,0)
    TweenService:Create(KFrame, TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0,420,0,300),
        Position = UDim2.new(0.5,-210,0.5,-150)
    }):Play()

    -- Attente vérification
    repeat task.wait(0.1) until keyVerified or not KeyGui.Parent
    if not keyVerified then return end
end

