    local Lbl = Instance.new("TextLabel", F)
    Lbl.Size=UDim2.new(1,-12,0,18); Lbl.Position=UDim2.new(0,12,0,6)
    Lbl.BackgroundTransparency=1; Lbl.Text=text
    Lbl.Font=Enum.Font.GothamBold; Lbl.TextSize=13
