createSection("Wallhack", "ESP — Wallhack")

createToggle("Wallhack","Red ESP",settings.redESP,function(enabled)
    settings.redESP=enabled
    if enabled then
        settings.rainbowESP=false
        notify("Wallhack","Red ESP activé",2)
        local function addESP(plr)
            if plr==player then return end
            local function onChar(char)
                task.wait(0.1); if not char then return end
                if highlights[plr] then pcall(function() highlights[plr]:Destroy() end) end
                local hl=Instance.new("Highlight"); hl.Adornee=char
                hl.FillColor=settings.espColor; hl.OutlineColor=settings.espColor
                hl.FillTransparency=settings.espTransparency; hl.OutlineTransparency=0
                hl.Parent=char; highlights[plr]=hl
            end
            if plr.Character then onChar(plr.Character) end
            plr.CharacterAdded:Connect(onChar)
        end
        for _,p in pairs(Players:GetPlayers()) do addESP(p) end
        table.insert(connections, Players.PlayerAdded:Connect(addESP))
    else
        for _,h in pairs(highlights) do pcall(function() h:Destroy() end) end; highlights={}
    end
end)

createToggle("Wallhack","Rainbow ESP",settings.rainbowESP,function(enabled)
    settings.rainbowESP=enabled
    if enabled then
        settings.redESP=false
        notify("Wallhack","Rainbow ESP activé",2)
        local function addR(plr)
            if plr==player then return end
            local function onChar(char)
                task.wait(0.1); if not char then return end
                if highlights[plr] then pcall(function() highlights[plr]:Destroy() end) end
                local hl=Instance.new("Highlight"); hl.Adornee=char
                hl.FillColor=Color3.fromHSV(0,1,1); hl.OutlineColor=Color3.fromHSV(0,1,0.8)
                hl.FillTransparency=settings.espTransparency; hl.OutlineTransparency=0
                hl.Parent=char; highlights[plr]=hl
            end
            if plr.Character then onChar(plr.Character) end
            plr.CharacterAdded:Connect(onChar)
        end
        for _,p in pairs(Players:GetPlayers()) do addR(p) end
        table.insert(connections, Players.PlayerAdded:Connect(addR))
        table.insert(connections, RunService.RenderStepped:Connect(function()
            if settings.rainbowESP then
                rainbowHue=(rainbowHue+0.005)%1
                for _,h in pairs(highlights) do
                    if h and h.Parent then h.FillColor=Color3.fromHSV(rainbowHue,1,1); h.OutlineColor=Color3.fromHSV(rainbowHue,1,0.8) end
                end
            end
        end))
    else
        for _,h in pairs(highlights) do pcall(function() h:Destroy() end) end; highlights={}
    end
end)

createSlider("Wallhack","Transparence ESP",0,100,settings.espTransparency*100,"%",function(val)
    settings.espTransparency=val/100
    for _,h in pairs(highlights) do if h and h.Parent then h.FillTransparency=settings.espTransparency end end
end)

createColorPicker("Wallhack","Couleur ESP",settings.espColor,function(c)
    settings.espColor=c
    if settings.redESP then
        for _,h in pairs(highlights) do if h and h.Parent then h.FillColor=c; h.OutlineColor=c end end
    end
end)

