local ADMIN_CODE = "znkxvanouille"
local KEY_FILE   = "znk_key.txt"

-- Lire la key sauvegardée
local function getSavedKey()
    if isfile and isfile(KEY_FILE) then
        local ok, content = pcall(readfile, KEY_FILE)
        if ok then return content end
    end
    return nil
end

-- Vérifier si une key est valide
local function isKeyValid(key)
    return VALID_KEYS[key] == true
end

-- Sauvegarder la key
local function saveKey(key)
    pcall(writefile, KEY_FILE, key)
end

-- Vérification initiale
