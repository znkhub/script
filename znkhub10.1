local minimized = false
local function setMin(state)
    minimized=state
    if state then
        TweenService:Create(Main, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
            Size=UDim2.new(0,MAIN_W,0,TITLEBAR_H)
        }):Play()
        Sidebar.Visible=false; Content.Visible=false; MinBtn.Text="□"
    else
        Sidebar.Visible=true; Content.Visible=true
        TweenService:Create(Main, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size=UDim2.new(0,MAIN_W,0,MAIN_H)
        }):Play()
        MinBtn.Text="─"
    end
end

MinBtn.MouseButton1Click:Connect(function() setMin(not minimized) end)
CloseBtn.MouseButton1Click:Connect(function()
    notify("ZNK Hub","Fermé !",2)
    cleanup(); task.wait(0.5); ScreenGui:Destroy()
end)

