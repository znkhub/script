-- ========================================
-- NOTIFICATIONS
-- ========================================

local function notify(title, msg, duration)
    local ng = Instance.new("ScreenGui")
    ng.ResetOnSpawn = false
    ng.DisplayOrder = 999999998
    pcall(function()
        if gethui then ng.Parent = gethui() else ng.Parent = CoreGui end
    end)

    local N = Instance.new("Frame", ng)
    N.Size = UDim2.new(0,300,0,70)
    N.Position = UDim2.new(1,320,0,20+activeNotifs*80)
    N.BackgroundColor3 = Color3.fromRGB(10,15,30)
    N.BorderSizePixel = 0
    Instance.new("UICorner", N).CornerRadius = UDim.new(0,10)
    local ns = Instance.new("UIStroke", N)
    ns.Color = Color3.fromRGB(30,100,255)
    ns.Thickness = 2

    local ic = Instance.new("TextLabel", N)
    ic.Size=UDim2.new(0,38,0,38); ic.Position=UDim2.new(0,10,0.5,-19)
    ic.BackgroundTransparency=1; ic.Text="💎"
    ic.Font=Enum.Font.GothamBold; ic.TextSize=26
    ic.TextColor3=Color3.fromRGB(30,120,255)

    local tl = Instance.new("TextLabel", N)
    tl.Size=UDim2.new(1,-54,0,22); tl.Position=UDim2.new(0,52,0,12)
    tl.BackgroundTransparency=1; tl.Text=title
    tl.Font=Enum.Font.GothamBold; tl.TextSize=14
    tl.TextColor3=Color3.fromRGB(255,255,255)
    tl.TextXAlignment=Enum.TextXAlignment.Left

    local ml = Instance.new("TextLabel", N)
    ml.Size=UDim2.new(1,-54,0,26); ml.Position=UDim2.new(0,52,0,36)
    ml.BackgroundTransparency=1; ml.Text=msg
    ml.Font=Enum.Font.Gotham; ml.TextSize=12
    ml.TextColor3=Color3.fromRGB(180,180,220)
    ml.TextXAlignment=Enum.TextXAlignment.Left
    ml.TextWrapped=true

    activeNotifs += 1
    TweenService:Create(N, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = UDim2.new(1,-320,0,20+(activeNotifs-1)*80)
    }):Play()

    task.delay(duration or 3, function()
        TweenService:Create(N, TweenInfo.new(0.3), {
            Position = UDim2.new(1,320,0,20+(activeNotifs-1)*80)
        }):Play()
        task.wait(0.35)
        activeNotifs = math.max(0, activeNotifs-1)
        ng:Destroy()
    end)
end

-- ========================================
-- CLEANUP
-- ========================================

local function cleanup()
    for _, c in pairs(connections) do pcall(function() c:Disconnect() end) end
    for _, h in pairs(highlights) do pcall(function() h:Destroy() end) end
    if flyConnection then flyConnection:Disconnect() end
    connections={}; highlights={}; lockedTarget=nil
    if humanoid then
        humanoid.WalkSpeed = originalValues.walkSpeed
        humanoid.JumpPower = originalValues.jumpPower
    end
    camera.FieldOfView = originalValues.fov
    if fovCircle then pcall(function() fovCircle:Remove() end) end
end

