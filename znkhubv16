local activeNotifs = 0
local function notify(title, msg, duration)
    local ng = Instance.new("ScreenGui")
    ng.ResetOnSpawn = false; ng.DisplayOrder = 999999999
    pcall(function() if gethui then ng.Parent = gethui() else ng.Parent = CoreGui end end)
    local N = Instance.new("Frame", ng)
    N.Size = UDim2.new(0,300,0,70); N.Position = UDim2.new(1,320,0,20+activeNotifs*80)
    N.BackgroundColor3 = panelDark; N.BorderSizePixel = 0
    Instance.new("UICorner",N).CornerRadius = UDim.new(0,10)
    local ns = Instance.new("UIStroke",N); ns.Color = currentTheme; ns.Thickness = 2
    local ic = Instance.new("TextLabel",N); ic.Size = UDim2.new(0,40,0,40); ic.Position = UDim2.new(0,10,0.5,-20)
    ic.BackgroundTransparency = 1; ic.Text = "⚡"; ic.Font = Enum.Font.GothamBold; ic.TextSize = 28; ic.TextColor3 = currentTheme
    local tl = Instance.new("TextLabel",N); tl.Size = UDim2.new(1,-60,0,22); tl.Position = UDim2.new(0,55,0,12)
    tl.BackgroundTransparency = 1; tl.Text = title; tl.Font = Enum.Font.GothamBold; tl.TextSize = 14
    tl.TextColor3 = Color3.fromRGB(255,255,255); tl.TextXAlignment = Enum.TextXAlignment.Left
    local ml = Instance.new("TextLabel",N); ml.Size = UDim2.new(1,-60,0,28); ml.Position = UDim2.new(0,55,0,36)
    ml.BackgroundTransparency = 1; ml.Text = msg; ml.Font = Enum.Font.Gotham; ml.TextSize = 12
    ml.TextColor3 = textMuted; ml.TextXAlignment = Enum.TextXAlignment.Left; ml.TextWrapped = true
    activeNotifs = activeNotifs + 1
    TweenService:Create(N,TweenInfo.new(0.4,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{
        Position = UDim2.new(1,-320,0,20+(activeNotifs-1)*80)}):Play()
    task.delay(duration or 3, function()
        TweenService:Create(N,TweenInfo.new(0.3),{Position=UDim2.new(1,320,0,20+(activeNotifs-1)*80)}):Play()
        task.wait(0.4); activeNotifs = activeNotifs-1; ng:Destroy()
    end)
end
 
