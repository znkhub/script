-- Fonction centrale de setup des features après spawn (appelée à chaque respawn)
local function setupCharacterFeatures()
    character = player.Character or player.CharacterAdded:Wait()
    humanoid = character:WaitForChild("Humanoid")
    rootpart = character:WaitForChild("HumanoidRootPart")
 
    -- Ré-applique walkspeed si activé
    if settings and settings.speedEnabled then
        humanoid.WalkSpeed = settings.walkSpeed
    end
    -- Ré-applique jumppower
    if settings and settings.jumpPower then
        humanoid.JumpPower = settings.jumpPower
    end
    -- Ré-applique le fly si activé
    if settings and settings.fly then
        task.spawn(function()
            task.wait(0.2)
            local bv = Instance.new("BodyVelocity")
            bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            bv.Velocity = Vector3.zero
            bv.Parent = rootpart
 
            local bg = Instance.new("BodyGyro")
            bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            bg.P = 10000
            bg.D = 500
            bg.Parent = rootpart
 
            if flyConnection then flyConnection:Disconnect() end
            flyConnection = RunService.Heartbeat:Connect(function()
                if not settings.fly or not rootpart or not rootpart.Parent then
                    if flyConnection then flyConnection:Disconnect() end
                    return
                end
                local dir = Vector3.zero
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + camera.CFrame.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - camera.CFrame.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - camera.CFrame.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + camera.CFrame.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0, 1, 0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - Vector3.new(0, 1, 0) end
                if bv and bv.Parent then
                    bv.Velocity = dir.Magnitude > 0 and dir.Unit * settings.flySpeed or Vector3.zero
                end
                if bg and bg.Parent then
                    bg.CFrame = camera.CFrame
                end
            end)
        end)
    end
    -- Ré-applique le noclip si activé
    if settings and settings.noclip then
        -- Le loop noclip est dans RunService.Stepped ci-dessous, il se gère tout seul via settings.noclip
    end
    -- Ré-applique les ESP
    if settings and (settings.redESP or settings.rainbowESP) then
        task.spawn(function()
            task.wait(0.3)
            local function addHL(plr)
                if plr == player then return end
                local function onChar(char)
                    task.wait(0.1)
                    if not char then return end
                    if highlights[plr] then pcall(function() highlights[plr]:Destroy() end) end
                    local hl = Instance.new("Highlight")
                    hl.Name = "ZNKESP"
                    hl.Adornee = char
                    if settings.rainbowESP then
                        hl.FillColor = Color3.fromHSV(0, 1, 1)
                        hl.OutlineColor = Color3.fromHSV(0, 1, 0.8)
                    else
                        hl.FillColor = settings.espColor
                        hl.OutlineColor = settings.espColor
                    end
                    hl.FillTransparency = settings.espTransparency
                    hl.OutlineTransparency = 0
                    hl.Parent = char
                    highlights[plr] = hl
                end
                if plr.Character then onChar(plr.Character) end
                plr.CharacterAdded:Connect(onChar)
            end
            for _, p in pairs(Players:GetPlayers()) do addHL(p) end
        end)
    end
end
 
