local VALID_KEYS = {
    "ZNK-2024-ELITE",
    "ZNK-AMI1-2024",
    "ZNK-AMI2-2024",
    "znkxvanouille",
}
 
local KEY_FILE       = "znk_key.txt"
local ACCOUNTS_FILE  = "znk_accounts.json"
local CUSTOM_KEYS_FILE = "znk_custom_keys.json"
 
-- Charge les comptes enregistrés
local function loadAccounts()
    if isfile and isfile(ACCOUNTS_FILE) then
        local ok, data = pcall(function()
            return HttpService_:JSONDecode(readfile(ACCOUNTS_FILE))
        end)
        if ok and data then return data end
    end
    return {}
end
 
-- Sauvegarde les comptes
local function saveAccounts(accounts)
    pcall(function()
        writefile(ACCOUNTS_FILE, HttpService_:JSONEncode(accounts))
    end)
end
 
-- Charge les keys custom
local function loadCustomKeys()
    if isfile and isfile(CUSTOM_KEYS_FILE) then
        local ok, data = pcall(function()
            return HttpService_:JSONDecode(readfile(CUSTOM_KEYS_FILE))
        end)
        if ok and data then return data end
    end
    return {}
end
 
-- Sauvegarde les keys custom
local function saveCustomKeys(keys)
    pcall(function()
        writefile(CUSTOM_KEYS_FILE, HttpService_:JSONEncode(keys))
    end)
end
 
-- Vérifie si une key est valide (builtin + custom)
local function isKeyValid(key)
    if key == nil or key == "" then return false end
    for _, k in pairs(VALID_KEYS) do
        if key == k then return true end
    end
    local customKeys = loadCustomKeys()
    for _, k in pairs(customKeys) do
        if key == k then return true end
    end
    return false
end
 
-- Vérifie si la key sauvegardée est valide
local function isSavedKeyValid()
    if isfile and isfile(KEY_FILE) then
        local saved = readfile(KEY_FILE)
        return isKeyValid(saved)
    end
    return false
end
 
-- Vérifie les credentials d'un compte
local function checkAccount(username, password)
    local accounts = loadAccounts()
    local user = username:lower()
    if accounts[user] and accounts[user].password == password then
        return true, accounts[user]
    end
    return false, nil
end
 
-- Crée ou met à jour un compte
local function saveAccount(username, password, keyUsed)
    local accounts = loadAccounts()
    accounts[username:lower()] = {
        password = password,
        keyUsed = keyUsed or "",
        createdAt = os.time and os.time() or 0
    }
    saveAccounts(accounts)
end
 
-- Vérifie si un compte existe
local function accountExists(username)
    local accounts = loadAccounts()
    return accounts[username:lower()] ~= nil
end
 
