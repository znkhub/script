local function updateRedESP()
    for _, h in pairs(highlights) do pcall(function() h:Destroy() end) end; highlights = {}
    if not settings.redESP then return end
    local function addESP(plr)
        if plr == player then return end
        local function onChar(char)
            task.wait(0.1); if not char or not settings.redESP then return end
            local hl = Instance.new("Highlight"); hl.Name = "ZNKESP"; hl.Adornee = char
            hl.FillColor = settings.espColor; hl.OutlineColor = settings.espColor
            hl.FillTransparency = settings.espTransparency; hl.OutlineTransparency = 0
            hl.Parent = char; highlights[plr] = hl
        end
        if plr.Character then onChar(plr.Character) end
        plr.CharacterAdded:Connect(onChar)
    end
    for _, p in pairs(Players:GetPlayers()) do addESP(p) end
end

local function updateFOV()
    if fovCircle then fovCircle.Visible = false end
    if not (settings.aimbot or settings.aimbotLock) or not settings.showFOV then return end
    if not fovCircle then
        fovCircle = Drawing.new("Circle"); fovCircle.Thickness = 2.5
        fovCircle.NumSides = 100; fovCircle.Filled = false
    end
    fovCircle.Color = settings.fovColor
    fovCircle.Radius = settings.aimbotFOV
    fovCircle.Visible = true
end

