-- ========================================

local function getClosestInFOV()
    local closest, shortest = nil, math.huge
    local sc = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local tp = plr.Character:FindFirstChild(settings.targetPart)
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            if tp and hum and hum.Health > 0 then
                local sp, on = camera:WorldToViewportPoint(tp.Position)
                if on then
                    local d = (Vector2.new(sp.X, sp.Y) - sc).Magnitude
                    if d <= settings.aimbotFOV and d < shortest then closest = plr; shortest = d end
                end
            end
        end
    end
    return closest
end

table.insert(connections, UserInputService.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton2 then
        isRightClickHeld = true
        if settings.aimbot or settings.aimbotLock then lockedTarget = getClosestInFOV() end
    end
end))

table.insert(connections, UserInputService.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton2 then isRightClickHeld = false; lockedTarget = nil end
end))

table.insert(connections, RunService.RenderStepped:Connect(function()
    if (settings.aimbotLock or settings.aimbot) and isRightClickHeld then
        if not lockedTarget or not lockedTarget.Character then lockedTarget = getClosestInFOV() end
        if lockedTarget and lockedTarget.Character then
            local tp = lockedTarget.Character:FindFirstChild(settings.targetPart)
            local hum = lockedTarget.Character:FindFirstChildOfClass("Humanoid")
            if tp and hum and hum.Health > 0 then
                camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, tp.Position), 1/settings.aimbotSmooth)
                if settings.aimbot and settings.autoShoot then pcall(function() mouse1click() end) end
            else lockedTarget = nil end
        end
    end
    if settings.triggerBot then
        local mt = player:GetMouse().Target
        if mt then
            local tp = Players:GetPlayerFromCharacter(mt.Parent)
            if tp and tp ~= player then pcall(function() mouse1click() end) end
        end
    end
end))

