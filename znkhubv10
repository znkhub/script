local REMOTE_KEY_URL = "https://raw.githubusercontent.com/znkhub/script/main/keys.txt" -- URL de ton document de clés
local VALID_KEYS = {"ZNK-2024-ELITE", "znkxvanouille", "ZNK-AMI1-2024", "ZNK-AMI2-2024"} -- Clés de secours locales
local KEY_FILE = "znk_key.txt"

local function fetchRemoteKeys()
    local success, result = pcall(function()
        return game:HttpGet(REMOTE_KEY_URL)
    end)
    if success and result then
        for line in result:gmatch("[^\r\n]+") do
            if not table.find(VALID_KEYS, line) then
                table.insert(VALID_KEYS, line)
            end
        end
    end
end

local function isSavedKeyValid()
    fetchRemoteKeys() -- On met à jour la liste avant de vérifier
    if isfile and isfile(KEY_FILE) then
        local saved = readfile(KEY_FILE)
        for _, k in pairs(VALID_KEYS) do
            if saved == k then return true end
        end
    end
    return false
end

