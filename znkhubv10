        if rootpart:FindFirstChild("BodyVelocity") then rootpart.BodyVelocity:Destroy() end
        if rootpart:FindFirstChild("BodyGyro") then rootpart.BodyGyro:Destroy() end
        for _, v in pairs(rootpart:GetChildren()) do
