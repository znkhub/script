createToggle(MoveTab, "Fly", "Fly", function()
    if not activeFeatures["Fly"] then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local bg = Instance.new("BodyGyro", hrp)
    bg.D = 9999; bg.P = 9999; bg.MaxTorque = Vector3.new(9999, 9999, 9999)
    local bv = Instance.new("BodyVelocity", hrp)
    bv.Velocity = Vector3.zero; bv.MaxForce = Vector3.new(9999, 9999, 9999)
    local flySpeed = sliderValues["FlySpeed"] or 50
    local c = RunService.Heartbeat:Connect(function()
        if not activeFeatures["Fly"] then
            c:Disconnect()
            featureLoops["Fly"] = nil
            bg:Destroy(); bv:Destroy()
            return
        end
        local cam = workspace.CurrentCamera
        local fwd = UserInputService:IsKeyDown(Enum.KeyCode.W)
        local bwd = UserInputService:IsKeyDown(Enum.KeyCode.S)
        local lft = UserInputService:IsKeyDown(Enum.KeyCode.A)
        local rgt = UserInputService:IsKeyDown(Enum.KeyCode.D)
        local up = UserInputService:IsKeyDown(Enum.KeyCode.Space)
        local dn = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift)
        local dir = Vector3.zero
        if fwd then dir = dir + cam.CFrame.LookVector end
        if bwd then dir = dir - cam.CFrame.LookVector end
        if lft then dir = dir - cam.CFrame.RightVector end
        if rgt then dir = dir + cam.CFrame.RightVector end
        if up then dir = dir + Vector3.new(0, 1, 0) end
        if dn then dir = dir - Vector3.new(0, 1, 0) end
        bv.Velocity = dir * flySpeed
        bg.CFrame = cam.CFrame
    end)
    featureLoops["Fly"] = c
end)

