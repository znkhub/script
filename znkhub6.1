    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(1, -40, 1, 0)
    lbl.Position = UDim2.new(0, 32, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = name
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 12
    lbl.TextColor3 = Color3.fromRGB(160, 195, 255)
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    -- Enregistre le callback et le bouton
    featureCallbacks[featureKey] = callback
    toggleButtons[featureKey] = row

    -- Applique visuellement l'état actuel
    local function updateVisual(state)
        if state then
            icon.Text = "🟢"
            icon.TextColor3 = Color3.fromRGB(80, 220, 80)
            row.BackgroundColor3 = Color3.fromRGB(15, 35, 90)
        else
            icon.Text = "🔴"
            icon.TextColor3 = Color3.fromRGB(255, 80, 80)
            row.BackgroundColor3 = Color3.fromRGB(12, 18, 38)
        end
    end

    -- Applique l'état initial si déjà en mémoire (chargé depuis config)
    if activeFeatures[featureKey] ~= nil then
        updateVisual(activeFeatures[featureKey])
    end

    btn.MouseButton1Click:Connect(function()
        local newState = not (activeFeatures[featureKey] or false)
        activeFeatures[featureKey] = newState
        updateVisual(newState)
        if newState then
            if callback then pcall(callback) end
        else
            -- Stoppe la boucle si elle existe
            if featureLoops[featureKey] then
                pcall(function()
                    if typeof(featureLoops[featureKey]) == "RBXScriptConnection" then
                        featureLoops[featureKey]:Disconnect()
                    elseif typeof(featureLoops[featureKey]) == "thread" then
                        task.cancel(featureLoops[featureKey])
                    end
                end)
                featureLoops[featureKey] = nil
            end
        end
        saveConfig()
    end)

    return row
end

-- Crée un slider
local function createSlider(parent, name, sliderKey, min, max, default, callback)
    local current = sliderValues[sliderKey] or default

    local row = Instance.new("Frame", parent)
    row.Size = UDim2.new(1, 0, 0, 52)
    row.BackgroundColor3 = Color3.fromRGB(12, 18, 38)
    row.BorderSizePixel = 0
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 7)

    local nameLbl = Instance.new("TextLabel", row)
    nameLbl.Size = UDim2.new(0.7, 0, 0, 22)
    nameLbl.Position = UDim2.new(0, 10, 0, 4)
    nameLbl.BackgroundTransparency = 1
    nameLbl.Text = name
    nameLbl.Font = Enum.Font.GothamBold
    nameLbl.TextSize = 12
    nameLbl.TextColor3 = Color3.fromRGB(160, 195, 255)
    nameLbl.TextXAlignment = Enum.TextXAlignment.Left

    local valLbl = Instance.new("TextLabel", row)
    valLbl.Size = UDim2.new(0.28, 0, 0, 22)
    valLbl.Position = UDim2.new(0.72, 0, 0, 4)
    valLbl.BackgroundTransparency = 1
    valLbl.Text = tostring(math.floor(current))
    valLbl.Font = Enum.Font.GothamBold
    valLbl.TextSize = 12
    valLbl.TextColor3 = Color3.fromRGB(80, 150, 255)
    valLbl.TextXAlignment = Enum.TextXAlignment.Right

    local track = Instance.new("Frame", row)
    track.Size = UDim2.new(1, -20, 0, 6)
    track.Position = UDim2.new(0, 10, 0, 32)
    track.BackgroundColor3 = Color3.fromRGB(20, 35, 70)
    track.BorderSizePixel = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(0, 3)

    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new((current - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(30, 100, 255)
    fill.BorderSizePixel = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 3)

    local thumb = Instance.new("Frame", track)
    thumb.Size = UDim2.new(0, 12, 0, 12)
    thumb.Position = UDim2.new((current - min) / (max - min), -6, 0.5, -6)
    thumb.BackgroundColor3 = Color3.fromRGB(80, 160, 255)
    thumb.BorderSizePixel = 0
    Instance.new("UICorner", thumb).CornerRadius = UDim.new(0.5, 0)

    sliderCallbacks[sliderKey] = callback

    local sliding = false
    local function updateSlider(v)
        v = math.clamp(v, min, max)
        v = math.floor(v * 10 + 0.5) / 10
        sliderValues[sliderKey] = v
        valLbl.Text = tostring(math.floor(v))
        local ratio = (v - min) / (max - min)
        fill.Size = UDim2.new(ratio, 0, 1, 0)
        thumb.Position = UDim2.new(ratio, -6, 0.5, -6)
        if callback then pcall(callback, v) end
        saveConfig()
    end

    -- Applique la valeur sauvegardée
    if sliderValues[sliderKey] then
        task.spawn(function()
            task.wait(0.1)
            updateSlider(sliderValues[sliderKey])
        end)
    end

    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = true
            local relX = i.Position.X - track.AbsolutePosition.X
            local ratio = math.clamp(relX / track.AbsoluteSize.X, 0, 1)
            updateSlider(min + (max - min) * ratio)
        end
    end)
    track.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then
            local relX = i.Position.X - track.AbsolutePosition.X
            local ratio = math.clamp(relX / track.AbsoluteSize.X, 0, 1)
            updateSlider(min + (max - min) * ratio)
        end
    end)

    return row
end

-- Crée un bouton simple
local function createButton(parent, label, callback)
    local row = Instance.new("Frame", parent)
    row.Size = UDim2.new(1, 0, 0, 36)
    row.BackgroundColor3 = Color3.fromRGB(12, 18, 38)
    row.BorderSizePixel = 0
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 7)

    local btn = Instance.new("TextButton", row)
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundColor3 = Color3.fromRGB(18, 45, 130)
    btn.Text = label
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    btn.TextColor3 = Color3.fromRGB(200, 220, 255)
    btn.AutoButtonColor = false
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 7)

    local btnGrad = Instance.new("UIGradient", btn)
    btnGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(15, 40, 120)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(25, 70, 200))
    })
    btnGrad.Rotation = 90

    btn.MouseEnter:Connect(function()
        TweenService_:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(25, 60, 180)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService_:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(18, 45, 130)}):Play()
    end)

    if callback then
        btn.MouseButton1Click:Connect(function()
            TweenService_:Create(btn, TweenInfo.new(0.08), {Size = UDim2.new(0.98, 0, 0.9, 0)}):Play()
            task.wait(0.08)
            TweenService_:Create(btn, TweenInfo.new(0.08), {Size = UDim2.new(1, 0, 1, 0)}):Play()
            pcall(callback)
        end)
    end

    return btn
end

