-- ✅ FIX PRINCIPAL : SAUVEGARDE CONFIG
-- ========================================

local CONFIG_FILE = "znk_config.json"

-- Tables de tracking des états et callbacks
local activeFeatures = {}   -- { featureName = true/false }
local sliderValues = {}     -- { sliderName = number }
local featureCallbacks = {} -- { featureName = function }
local sliderCallbacks = {}  -- { sliderName = function(value) }
local toggleButtons = {}    -- { featureName = ButtonInstance }
local featureLoops = {}     -- { featureName = connectionOrThread }

-- Sauvegarde la config dans znk_config.json
local function saveConfig()
    local data = {}
    for k, v in pairs(activeFeatures) do
        data[k] = v
    end
    for k, v in pairs(sliderValues) do
        data["slider_" .. k] = v
    end
    pcall(function()
        if writefile then
            writefile(CONFIG_FILE, HttpService:JSONEncode(data))
        end
    end)
end

-- ✅ FIX CLÉ : Applique visuellement l'état d'un toggle
local function applyToggleVisual(btn, state)
    if not btn or not btn.Parent then return end
    pcall(function()
        if state then
            btn.BackgroundColor3 = Color3.fromRGB(20, 80, 200)
            local lbl = btn:FindFirstChildWhichIsA("TextLabel")
            if not lbl then lbl = btn end
            if lbl.Text:sub(1,2) == "🔴" then
                lbl.Text = "🟢" .. lbl.Text:sub(3)
            end
        else
            btn.BackgroundColor3 = Color3.fromRGB(18, 28, 55)
            local lbl = btn:FindFirstChildWhichIsA("TextLabel")
            if not lbl then lbl = btn end
            if lbl.Text:sub(1,2) == "🟢" then
                lbl.Text = "🔴" .. lbl.Text:sub(3)
            end
        end
    end)
end

-- ✅ FIX CLÉ : Reconnecte TOUTES les features actives après un respawn
local function reconnectFeatures()
    for featureName, state in pairs(activeFeatures) do
        if state and featureCallbacks[featureName] then
            -- Stoppe la boucle précédente si elle existe
            if featureLoops[featureName] then
                pcall(function()
                    if typeof(featureLoops[featureName]) == "RBXScriptConnection" then
                        featureLoops[featureName]:Disconnect()
                    elseif typeof(featureLoops[featureName]) == "thread" then
                        task.cancel(featureLoops[featureName])
                    end
                end)
                featureLoops[featureName] = nil
            end
            pcall(featureCallbacks[featureName])
        end
    end
    for sliderName, value in pairs(sliderValues) do
        if sliderCallbacks[sliderName] then
            pcall(sliderCallbacks[sliderName], value)
        end
    end
end

-- ✅ FIX CLÉ : Charge la config ET réapplique tout (plus besoin de retoggler !)
local function loadAndApplyConfig()
    if not (isfile and isfile(CONFIG_FILE)) then return end
    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(CONFIG_FILE))
    end)
    if not ok or type(data) ~= "table" then return end

    -- Sépare sliders et toggles
    for k, v in pairs(data) do
        if k:sub(1, 7) == "slider_" then
            local name = k:sub(8)
            sliderValues[name] = v
        else
            activeFeatures[k] = v
        end
    end

    -- Applique les features après que la GUI soit construite
    task.wait(0.3)
    for k, v in pairs(activeFeatures) do
        if v and featureCallbacks[k] then
            pcall(featureCallbacks[k])
        end
        if toggleButtons[k] then
            applyToggleVisual(toggleButtons[k], v)
        end
    end
    for name, value in pairs(sliderValues) do
        if sliderCallbacks[name] then
            pcall(sliderCallbacks[name], value)
        end
    end
end

