const sliders={speed:16,fov:90};
const TABS=[{key:'player',icon:'🏃',lbl:'tab_player'},{key:'combat',icon:'⚔️',lbl:'tab_combat'},{key:'world',icon:'🌍',lbl:'tab_world'},{key:'visual',icon:'👁️',lbl:'tab_visual'},{key:'misc',icon:'⚙️',lbl:'tab_misc'}];
const TAB_COLORS={player:['#1e64ff','#2878ff','#4090ff','#2878ff','#1e64ff'],combat:['#ff2222','#ff4444','#ff6666','#ff4444','#ff2222'],world:['#22cc66','#33dd77','#44ee88','#33dd77','#22cc66'],visual:['#aa44ff','#bb55ff','#cc66ff','#bb55ff','#aa44ff'],misc:['#ff9900','#ffaa22','#ffbb44','#ffaa22','#ff9900']};
const t=()=>T[lang]||T.fr;
function setColorBar(id,colors){document.getElementById(id).innerHTML=colors.map(c=>`<span style="flex:1;background:${c}"></span>`).join('')}
function buildLangDropdown(which){document.getElementById(which+'-lang-dropdown').innerHTML=LANGS.map(l=>`<button class="${l.code===lang?'active':''}" onclick="selectLang('${which}','${l.code}')">${l.label}</button>`).join('')}
function toggleLangMenu(which){const btn=document.getElementById(which+'-lang-btn');const dd=document.getElementById(which+'-lang-dropdown');const open=dd.style.display==='none';document.querySelectorAll('.lang-dropdown').forEach(d=>d.style.display='none');document.querySelectorAll('.lang-btn').forEach(b=>b.classList.remove('open'));if(open){buildLangDropdown(which);dd.style.display='block';btn.classList.add('open')}}
function selectLang(which,code){lang=code;document.querySelectorAll('.lang-dropdown').forEach(d=>d.style.display='none');document.querySelectorAll('.lang-btn').forEach(b=>b.classList.remove('open'));const lbl=LANGS.find(l=>l.code===code).label;document.getElementById('key-lang-label').textContent=lbl;document.getElementById('hub-lang-label').textContent=lbl;renderKeyScreen();renderHub()}
document.addEventListener('click',e=>{if(!e.target.closest('.lang-btn')&&!e.target.closest('.lang-dropdown')){document.querySelectorAll('.lang-dropdown').forEach(d=>d.style.display='none');document.querySelectorAll('.lang-btn').forEach(b=>b.classList.remove('open'))}});
function renderKeyScreen(){const tr=t();document.getElementById('k-title').textContent=tr.key_title;document.getElementById('k-sub').textContent=tr.key_sub;document.getElementById('k-label').textContent=tr.key_label;document.getElementById('key-input').placeholder=tr.key_placeholder;document.getElementById('k-confirm').textContent=tr.confirm_btn;document.getElementById('k-info').textContent=tr.key_info;setColorBar('key-colorbar',['#1e64ff','#3d8bff','#5ba3ff','#3d8bff','#1e64ff','#0a2a8f','#1e64ff'])}
function setStatus(msg,color){const el=document.getElementById('k-status');el.textContent=msg;el.style.color=color}
function validateKey(){if(keyLocked)return;const val=document.getElementById('key-input').value.trim();if(VALID_KEYS.includes(val)){setStatus(t().valid_key,'#44ff88');document.getElementById('k-confirm').disabled=true;setTimeout(showHub,1200)}else{keyAttempts++;if(keyAttempts>=3){setStatus(t().locked_msg,'#ff9900');keyLocked=true;document.getElementById('k-confirm').disabled=true;setTimeout(()=>{keyLocked=false;keyAttempts=0;document.getElementById('k-confirm').disabled=false;setStatus('','#ff4444')},30000)}else{setStatus(t().invalid_key,'#ff4444')}}}
document.getElementById('key-input').addEventListener('keydown',e=>{if(e.key==='Enter')validateKey()});
function showHub(){document.getElementById('key-screen').style.display='none';document.getElementById('hub-screen').style.display='block';renderHub()}
function renderHub(){const tr=t();document.getElementById('hub-subtitle').textContent=tr.hub_subtitle;document.getElementById('tabs-row').innerHTML=TABS.map(tab=>`<button class="tab-btn${activeTab===tab.key?' active':''}" onclick="setTab('${tab.key}')"><span class="t-ico">${tab.icon}</span><span class="t-lbl">${tr[tab.lbl]}</span></button>`).join('');renderContent(tr);const cols=TAB_COLORS[activeTab];setColorBar('hub-colorbar-top',cols);setColorBar('hub-colorbar-bot',cols)}
function setTab(key){activeTab=key;renderHub()}
function toggleHTML(key,label,color=''){const on=toggles[key];return`<div class="toggle-row${on?' on':''} ${color}" onclick="doToggle('${key}')"><span class="lbl">${label}</span><div class="switch"></div></div>`}
function doToggle(key){toggles[key]=toggles[key]?0:1;renderHub()}
function sliderHTML(key,label,min,max){const val=sliders[key];const pct=((val-min)/(max-min))*100;return`<div class="slider-row"><div class="slider-top"><span class="s-lbl">${label}</span><span class="s-val" id="sv-${key}">${val}</span></div><input type="range" min="${min}" max="${max}" value="${val}" style="background:linear-gradient(to right,#1e64ff ${pct}%,#1a2d60 ${pct}%)" oninput="doSlider('${key}',this)"/></div>`}
function doSlider(key,el){sliders[key]=parseInt(el.value);const pct=((sliders[key]-parseInt(el.min))/(parseInt(el.max)-parseInt(el.min)))*100;el.style.background=`linear-gradient(to right,#1e64ff ${pct}%,#1a2d60 ${pct}%)`;const sv=document.getElementById('sv-'+key);if(sv)sv.textContent=sliders[key]}
function secHTML(label){return`<div class="sec-head"><div class="line"></div><span>${label}</span><div class="line"></div></div>`}
function creditsHTML(){return`<div class="credits-card"><div class="c-ico">💎</div><div class="c-name">ZNK HUB BEST CHEAT</div><div class="c-ver">v4.0 ULTIMATE</div><div class="c-disc">discord.gg/znkhub</div></div>`}
function renderContent(tr){let h='';switch(activeTab){case'player':h+=secHTML(tr.sec_movement)+toggleHTML('speed_hack',tr.speed_hack,'blue')+sliderHTML('speed',tr.speed_label,1,100)+toggleHTML('fly_hack',tr.fly_hack,'cyan')+toggleHTML('noclip',tr.noclip,'purple')+toggleHTML('inf_jump',tr.inf_jump,'green')+secHTML(tr.sec_utility)+toggleHTML('teleport',tr.teleport,'orange')+toggleHTML('god_mode',tr.god_mode,'yellow');break;case'combat':h+=secHTML(tr.sec_aim)+toggleHTML('aimbot',tr.aimbot,'red')+sliderHTML('fov',tr.fov_label,10,360)+toggleHTML('silent_aim',tr.silent_aim,'red')+secHTML(tr.sec_enemy)+toggleHTML('no_recoil',tr.no_recoil,'orange')+toggleHTML('inf_ammo',tr.inf_ammo,'pink')+toggleHTML('speed_bullet',tr.speed_bullet,'red');break;case'world':h+=secHTML(tr.sec_env)+toggleHTML('fullbright',tr.fullbright,'yellow')+toggleHTML('no_fog',tr.no_fog,'green')+secHTML(tr.sec_time)+toggleHTML('time_day',tr.time_day,'yellow')+toggleHTML('time_night',tr.time_night,'purple')+secHTML(tr.sec_other)+toggleHTML('weather',tr.weather,'cyan');break;case'visual':h+=secHTML(tr.sec_detection)+toggleHTML('esp_box',tr.esp_box,'purple')+toggleHTML('esp_names',tr.esp_names,'purple')+toggleHTML('xray',tr.xray,'cyan')+secHTML(tr.sec_enemy_vis)+toggleHTML('tracers',tr.tracers,'pink')+toggleHTML('wallhack',tr.wallhack,'purple')+toggleHTML('chams',tr.chams,'pink')+secHTML(tr.sec_ui)+toggleHTML('crosshair',tr.crosshair,'blue');break;case'misc':h+=secHTML(tr.sec_game)+toggleHTML('anti_afk',tr.anti_afk,'green')+toggleHTML('auto_farm',tr.auto_farm,'orange')+toggleHTML('inf_money',tr.inf_money,'yellow')+secHTML(tr.sec_other)+creditsHTML();break}document.getElementById('hub-content').innerHTML=h}
renderKeyScreen();
</script>
</body>
</html>
